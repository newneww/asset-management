# ===== Apps Script Web App (ฐานข้อมูล Google Sheets) =====
# URL ที่ได้จากการ Deploy Apps Script เป็น Web app
# (Apps Script Editor > Deploy > New deployment > Web app > ลงท้ายด้วย /exec)
VITE_API_URL=

# โหมดสาธิต (ดู UI โดยไม่ต้องต่อ backend จริง) — ตั้ง =1 เพื่อใช้ข้อมูลตัวอย่างในหน่วยความจำ
VITE_DEMO=
